          }
        },
        "devstral-2-123b": {
          "name": "devstral-2-123b",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "reasoning": false,
          "tool_call": true,
          "options": {
            "temperature": 0.7,
            "top_p": 0.9
          }
        }
      }
    },
    "lite-llm": {
      "npm": "@ai-sdk/litellm",
      "options": {
        "baseURL": "https://api.openai.com/v1"
      },
      "models": {
        "nv-embed-v1": {
          "name": "nv-embed-v1",
          "supports_embeddings": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "reasoning": false,
          "tool_call": false
        }
      }
    },
    "opencode": {
      "blacklist": [
        "claude-opus-4-7",
        "claude-opus-4-6",
        "claude-opus-4-5",
        "claude-opus-4-1",
        "claude-sonnet-4-6",
