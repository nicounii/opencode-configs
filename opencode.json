            "temperature": 1.0,
            "top_p": 0.95
          }
        },
        "gemini-3.1-pro-high": {
          "name": "gemini-3.1-pro-high",
          "tool_call": true,
          "options": {
            "temperature": 1.0,
            "top_p": 0.95
          }
        },
        "gemini-3.1-pro-low": {
          "name": "gemini-3.1-pro-low",
          "tool_call": true,
          "options": {
            "temperature": 1.0,
            "top_p": 0.95
          }
        },
        "gemini-pro-agent": {
          "name": "gemini-pro-agent",
          "tool_call": true,
