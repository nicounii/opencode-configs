        },
        "claude-opus-4-6-thinking": {
          "name": "claude-opus-4-6-thinking",
          "tool_call": true,
          "options": {
            "temperature": 1.0,
            "top_p": 0.9
          }
        },
        "step-3.5-flash": {
          "name": "step-3.5-flash",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "reasoning": false,
          "tool_call": true,
          "options": {
            "temperature": 0.5,
            "top_p": 0.7,
            "repeat_penalty": 1.2
          }
        },
        "minimax-m2.7": {
          "name": "minimax-m2.7",
