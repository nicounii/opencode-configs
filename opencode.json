{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "skill": {
      "*": "allow"
    },
    "todoread": "allow",
    "todowrite": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "*.lock",
      "**/*.log",
      ".cache/**",
      "build/**",
      "__pycache__/**",
      ".venv/**",
      "venv/**"
    ]
  },
  "plugin": [
    "@nick-vi/opencode-type-inject@latest",
    "opencode-with-claude@latest",
    "opencode-historian@latest",
    "opencode-hive@latest",
    "@_davideast/stitch-mcp@latest",
    "opencode-antigravity-auth@latest",
    "oh-my-opencode-slim@latest",
    "./plugin/tokentracker.js",
    "context-mode",
    "opencode-agent-skills"
  ],
  "enabled_providers": [
    "nvidia",
    "opencode",
    "zai-coding-plan",
    "github-copilot",
    "CLIProxyAPI",
    "LiteLLM"
  ],
  "provider": {
    "anthropic": {
      "options": {
        "baseURL": "http://127.0.0.1:3456",
        "apiKey": "dummy"
      }
    },
    "CLIProxyAPI": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CLIProxyAPI",
      "options": {
        "baseURL": "http://127.0.0.1:8317/v1"
      },
      "models": {
        "gemini-2.5-flash": {
          "name": "gemini-2.5-flash",
          "tool_call": true,
          "options": {
            "temperature": 1.0,
            "top_p": 0.95
          }
        },
        "gemini-2.5-flash-lite": {
          "name": "gemini-2.5-flash-lite",
          "tool_call": true,
          "options": {
            "temperature": 1.0,
            "top_p": 0.95
          }
        },
        "gemini-3-flash": {
          "name": "gemini-3-flash",
          "tool_call": true,
          "options": {
            "temperature": 1.0,
            "top_p": 0.95
          }
        },
        "gemini-3-flash-agent": {
