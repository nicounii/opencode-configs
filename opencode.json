  },
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": ["context-mode"],
      "enabled": true
    },
    "codebase-memory": {
      "command": [
        "/home/mathew/.local/bin/codebase-memory-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "token-savior": {
      "command": [
        "/home/mathew/.local/venvs/token-savior/bin/token-savior"
      ],
      "enabled": true,
      "type": "local",
      "environment": {
        "TOKEN_SAVIOR_PROFILE": "lean"
      }
    },
    "notebooklm": {
      "command": [
        "/home/mathew/.local/bin/notebooklm-mcp"
      ],
      "enabled": true,
      "environment": {
        "NLM_PROFILE": "default"
      },
      "type": "local"
    },
    "stitch": {
      "type": "local",
      "command": [
        "npx",
        "@_davideast/stitch-mcp",
        "proxy"
      ],
      "environment": {
        "STITCH_API_KEY": ""
      }
    },
    "openspace": {
      "command": [
        "/home/mathew/.local/bin/openspace-mcp"
      ],
      "type": "local",
      "enabled": true,
      "toolTimeout": 1200,
      "environment": {
        "OPENSPACE_HOST_SKILL_DIRS": "/home/mathew/.config/opencode/skills",
        "OPENSPACE_WORKSPACE": "/home/mathew/.config/OpenSpace",
        "OPENSPACE_MODEL": "CLIProxyAPI/minimax-m2.7",
        "OPENSPACE_LLM_API_KEY": "97cbd90655c240e683670322b40e55b6.9nNdg8SqC1TvNIRV",
        "OPENSPACE_LLM_API_BASE": "http://127.0.0.1:8317/v1",
        "OPENSPACE_API_KEY": "sk-LzZsSyr2_8_auM6jHMHNKxMCOHAo0hC67Q7_kwh1diM"
      }
    },
    "vision": {
      "command": [
        "npx",
        "-y",
        "@z_ai/mcp-server"
      ],
      "enabled": true,
      "environment": {
        "Z_AI_API_KEY": "{env:Z_AI_API_KEY}",
        "Z_AI_MODE": "ZAI"
      },
      "type": "local"
    },
    "github": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "type": "local"
    },
    "atlassian": {
      "command": [
        "npx",
        "-y",
        "@atlassian/mcp-server"
      ],
      "enabled": true,
      "environment": {
        "ATLASSIAN_API_KEY": "{env:ATLASSIAN_API_KEY}",
        "ATLASSIAN_EMAIL": "{env:ATLASSIAN_EMAIL}",
        "ATLASSIAN_SITE": "{env:ATLASSIAN_SITE}"
      },
      "type": "local"
    },
    "figma": {
      "command": [
        "npx",
        "-y",
        "@anthropic-ai/figma-mcp"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    }
  },
  "lsp": true
}
